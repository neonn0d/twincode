#!/usr/bin/env node

import { existsSync, mkdirSync, readFileSync, writeFileSync } from 'fs'
import { join, dirname } from 'path'
import { homedir, platform } from 'os'
import { fileURLToPath, pathToFileURL } from 'url'
import { execSync } from 'child_process'
import { LOGO_LINES } from '../src/components/logoArt.js'

// Wipe all provider env vars so no stale shell values leak in
for (const k of [
  'ANTHROPIC_API_KEY', 'ANTHROPIC_BASE_URL', 'ANTHROPIC_MODEL',
  'OPENAI_API_KEY', 'OPENAI_BASE_URL', 'OPENAI_MODEL', 'OPENAI_API_FORMAT',
  'CLAUDE_CODE_USE_OPENAI', 'CLAUDE_CODE_USE_GEMINI',
  'GEMINI_API_KEY', 'GEMINI_MODEL',
]) delete process.env[k]
process.title = 'twin'

const __dirname = dirname(fileURLToPath(import.meta.url))
const distPath = join(__dirname, '..', 'dist', 'cli.mjs')
const MCP_SERVER_PATH = join(__dirname, '..', 'mcp', 'server.js')

const TWIN_DIR = join(homedir(), '.twincode')
const SETTINGS_PATH = join(TWIN_DIR, 'settings.json')
const CLAUDE_JSON_PATH = join(homedir(), '.claude.json')

const ESC = '\x1b['
const RESET = `${ESC}0m`
const DIM = `${ESC}2m`
const BOLD = `${ESC}1m`
const rgb = (r, g, b) => `${ESC}38;2;${r};${g};${b}m`
const ACCENT = rgb(100, 180, 255)
const GREEN = rgb(100, 200, 120)
const PURPLE = rgb(180, 120, 255)
const YELLOW = rgb(255, 200, 80)
const GRAY = rgb(100, 110, 120)
const RED = rgb(255, 100, 100)
const DIM_GRAY = `${ESC}2m`

// ── `twin update` — pull latest, rebuild, relink ─────────────────────
// `twin update`         fetch, and if behind, pull + rebuild
// `twin update --check` just report whether an update is available
if (process.argv[2] === 'update') {
  const root = join(__dirname, '..')
  const checkOnly = process.argv.includes('--check')
  const git = (args) => execSync(`git ${args}`, { cwd: root, encoding: 'utf8' }).trim()
  const findBun = () => {
    try { execSync('command -v bun', { stdio: 'ignore' }); return 'bun' } catch {}
    const local = join(homedir(), '.bun', 'bin', 'bun')
    return existsSync(local) ? local : null
  }
  try {
    if (!existsSync(join(root, '.git'))) {
      console.error(`${RED}twin: not a git install${RESET} — reinstall with:\n  curl -fsSL https://twincode.wtf/install.sh | bash`)
      process.exit(1)
    }
    console.log(`${DIM}checking for updates…${RESET}`)
    git('fetch --quiet origin')
    const behind = git('rev-list --count HEAD..@{u}')
    if (behind === '0') {
      console.log(`${GREEN}✓${RESET} twin is up to date.`)
      process.exit(0)
    }
    console.log(`${YELLOW}${behind}${RESET} update(s) available.`)
    if (checkOnly) {
      console.log(`${DIM}run ${RESET}${BOLD}twin update${RESET}${DIM} to install.${RESET}`)
      process.exit(0)
    }
    const bun = findBun()
    if (!bun) {
      console.error(`${RED}twin: bun not found${RESET} — reinstall with:\n  curl -fsSL https://twincode.wtf/install.sh | bash`)
      process.exit(1)
    }
    // Hard-reset to upstream rather than `git pull`: this is a managed
    // install dir, not a dev checkout, and `bun install` rewrites bun.lock —
    // so a plain pull would refuse to fast-forward over "local changes".
    execSync('git reset --hard @{u}', { cwd: root, stdio: 'inherit' })
    console.log(`${DIM}installing dependencies…${RESET}`)
    execSync(`"${bun}" install`, { cwd: root, stdio: 'inherit' })
    console.log(`${DIM}building…${RESET}`)
    execSync(`"${bun}" run build`, { cwd: root, stdio: 'inherit' })
    console.log(`${GREEN}✓ twin updated.${RESET} Restart twin to use the new version.`)
    process.exit(0)
  } catch (e) {
    console.error(`${RED}twin update failed:${RESET} ${e.message || e}`)
    console.error(`Reinstall with: curl -fsSL https://twincode.wtf/install.sh | bash`)
    process.exit(1)
  }
}

// Read a line in raw mode — masked (shows *) or plain (shows chars)
function readLine(masked = false) {
  return new Promise(resolve => {
    let value = ''
    process.stdin.setRawMode(true)
    process.stdin.resume()
    process.stdin.setEncoding('utf8')

    const onData = chunk => {
      for (const char of chunk) {
        if (char === '\x03') {
          process.stdout.write('\n')
          process.exit(0)
        }
        if (char === '\r' || char === '\n') {
          process.stdin.removeListener('data', onData)
          process.stdin.setRawMode(false)
          process.stdin.pause()
          process.stdout.write('\n')
          resolve(value)
          return
        }
        if (char === '\x7f' || char === '\b') {
          if (value.length > 0) {
            value = value.slice(0, -1)
            process.stdout.write('\b \b')
          }
          continue
        }
        if (char >= ' ') {
          value += char
          process.stdout.write(masked ? '*' : char)
        }
      }
    }

    process.stdin.on('data', onData)
  })
}

// Read a single keypress
function readKey() {
  return new Promise(resolve => {
    process.stdin.setRawMode(true)
    process.stdin.resume()
    process.stdin.setEncoding('utf8')
    const onData = chunk => {
      process.stdin.removeListener('data', onData)
      process.stdin.setRawMode(false)
      process.stdin.pause()
      resolve(chunk[0])
    }
    process.stdin.on('data', onData)
  })
}

// Detect Obsidian vaults from Obsidian's own config
function detectObsidianVaults() {
  const plat = platform()
  let obsidianConfigPath

  if (plat === 'linux') {
    // Try native install first, then Flatpak
    const native = join(homedir(), '.config', 'obsidian', 'obsidian.json')
    const flatpak = join(homedir(), '.var', 'app', 'md.obsidian.Obsidian', 'config', 'obsidian', 'obsidian.json')
    obsidianConfigPath = existsSync(native) ? native : flatpak
  } else if (plat === 'darwin') {
    obsidianConfigPath = join(homedir(), 'Library', 'Application Support', 'obsidian', 'obsidian.json')
  } else if (plat === 'win32') {
    obsidianConfigPath = join(process.env.APPDATA || '', 'obsidian', 'obsidian.json')
  }

  if (!obsidianConfigPath || !existsSync(obsidianConfigPath)) return []

  try {
    const config = JSON.parse(readFileSync(obsidianConfigPath, 'utf8'))
    const vaults = config.vaults || {}
    return Object.values(vaults)
      .filter(v => v.path && existsSync(v.path))
      .map(v => v.path)
  } catch {
    return []
  }
}

// Set up Python venv and install MCP deps
function setupMcpVenv() {
  try {
    execSync(`python3 -m venv "${MCP_VENV_PATH}"`, { stdio: 'pipe' })
    execSync(`"${MCP_VENV_PATH}/bin/pip" install mcp pyyaml -q`, { stdio: 'pipe' })
    return true
  } catch {
    return false
  }
}

// Register MCP server in ~/.claude.json
function registerMcpServer(vaultPath) {
  let config = {}
  if (existsSync(CLAUDE_JSON_PATH)) {
    try { config = JSON.parse(readFileSync(CLAUDE_JSON_PATH, 'utf8')) } catch {}
  }
  if (!config.mcpServers) config.mcpServers = {}
  config.mcpServers['twin'] = {
    command: 'node',
    args: [MCP_SERVER_PATH],
    env: { OBSIDIAN_VAULT: vaultPath },
    alwaysAllow: [
      'get_project_context', 'log_session', 'update_progress', 'session_start', 'session_end',
      'save_knowledge', 'get_knowledge', 'list_knowledge', 'search_knowledge', 'delete_knowledge',
      'set_next_steps', 'set_project_context',
    ],
  }
  writeFileSync(CLAUDE_JSON_PATH, JSON.stringify(config, null, 2))
}

async function runOnboarding() {
  console.log('')
  for (const line of LOGO_LINES) console.log(`${ACCENT}${line}${RESET}`)
  console.log('')
  const tagline = 'www.twincode.wtf'
  const pad = ' '.repeat(Math.floor((43 - tagline.length) / 2))
  console.log(`${pad}${ACCENT}${tagline}${RESET}`)
  console.log('')
  console.log(`  ${BOLD}Welcome to Twin${RESET} ${DIM}— AI coding agent by ${PURPLE}@neonn0d${RESET}`)
  console.log('')
  console.log(`  ${GRAY}─────────────────────────────────${RESET}`)
  console.log('')

  let apiKey = ''
  let model = ''
  let providerEnv = {}

  // Step 1: Provider
  console.log(`  ${YELLOW}Step 1/3${RESET} ${BOLD}Choose your AI provider${RESET}`)
  console.log('')
  console.log(`  ${ACCENT}1${RESET}  DeepSeek     ${DIM}Best for coding · 128K · ~$2/mo${RESET}  ${GREEN}platform.deepseek.com${RESET}`)
  console.log(`  ${ACCENT}2${RESET}  OpenRouter   ${DIM}Any model · one API key${RESET}          ${GREEN}openrouter.ai${RESET}`)
  console.log(`  ${ACCENT}3${RESET}  Evolink      ${DIM}Claude models · Anthropic API${RESET}    ${GREEN}evolink.ai${RESET}`)
  console.log(`  ${ACCENT}4${RESET}  StepFun      ${DIM}step-3.7-flash · fast${RESET}            ${GREEN}platform.stepfun.ai${RESET}`)
  console.log(`  ${ACCENT}5${RESET}  Custom       ${DIM}Any OpenAI-compatible API${RESET}`)
  console.log('')

  let provider = ''
  while (!provider) {
    process.stdout.write(`  ${ACCENT}›${RESET} Select provider [1-5]: `)
    const key = (await readLine(false)).trim()
    if (key === '1') provider = 'deepseek'
    else if (key === '2') provider = 'openrouter'
    else if (key === '3') provider = 'evolink'
    else if (key === '4') provider = 'stepfun'
    else if (key === '5') provider = 'custom'
    else console.log(`  ${RED}Pick 1–5${RESET}`)
  }
  console.log('')

  if (provider === 'deepseek') {
    console.log(`  ${YELLOW}Step 2a/3${RESET} ${BOLD}DeepSeek API Key${RESET}`)
    console.log(`  ${GRAY}Get yours at: platform.deepseek.com${RESET}`)
    console.log('')
    while (!apiKey.startsWith('sk-')) {
      process.stdout.write(`  ${ACCENT}›${RESET} Paste your API key: `)
      apiKey = (await readLine(true)).trim()
      if (!apiKey.startsWith('sk-')) console.log(`  ${RED}Invalid key — DeepSeek keys start with sk-${RESET}`)
    }
    console.log(`  ${GREEN}✔ Key saved${RESET}`)
    console.log('')

    console.log(`  ${YELLOW}Step 2b/3${RESET} ${BOLD}Choose your model${RESET}`)
    console.log('')
    console.log(`  ${ACCENT}1${RESET}  deepseek-v4-pro      ${DIM}Most capable · 128K${RESET}   ${GREEN}[recommended]${RESET}`)
    console.log(`  ${ACCENT}2${RESET}  deepseek-v4-flash    ${DIM}Fast · 128K${RESET}`)
    console.log(`  ${ACCENT}3${RESET}  deepseek-chat        ${DIM}Cheap · 128K${RESET}`)
    console.log(`  ${ACCENT}4${RESET}  deepseek-reasoner    ${DIM}Thinks · 128K${RESET}`)
    console.log('')
    const modelMap = { '1': 'deepseek-v4-pro', '2': 'deepseek-v4-flash', '3': 'deepseek-chat', '4': 'deepseek-reasoner' }
    while (!model) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select model [1-4]: `)
      const key = (await readLine(false)).trim()
      if (modelMap[key]) model = modelMap[key]
      else console.log(`  ${RED}Pick 1, 2, 3 or 4${RESET}`)
    }
    providerEnv = { OPENAI_BASE_URL: 'https://api.deepseek.com/v1', OPENAI_API_KEY: apiKey, OPENAI_MODEL: model }
  } else if (provider === 'openrouter') {
    console.log(`  ${YELLOW}Step 2a/3${RESET} ${BOLD}OpenRouter API Key${RESET}`)
    console.log(`  ${GRAY}Get yours at: openrouter.ai/keys${RESET}`)
    console.log('')
    while (!apiKey.startsWith('sk-or-')) {
      process.stdout.write(`  ${ACCENT}›${RESET} Paste your API key: `)
      apiKey = (await readLine(true)).trim()
      if (!apiKey.startsWith('sk-or-')) console.log(`  ${RED}Invalid key — OpenRouter keys start with sk-or-${RESET}`)
    }
    console.log(`  ${GREEN}✔ Key saved${RESET}`)
    console.log('')

    console.log(`  ${YELLOW}Step 2b/3${RESET} ${BOLD}Choose your model${RESET}`)
    console.log('')
    console.log(`  ${ACCENT}1${RESET}  deepseek/deepseek-chat-v3-0324      ${DIM}Best for coding · cheap${RESET}   ${GREEN}[recommended]${RESET}`)
    console.log(`  ${ACCENT}2${RESET}  anthropic/claude-sonnet-4-5         ${DIM}Claude · smart${RESET}`)
    console.log(`  ${ACCENT}3${RESET}  google/gemini-2.0-flash-001         ${DIM}Gemini · fast${RESET}`)
    console.log(`  ${ACCENT}4${RESET}  meta-llama/llama-3.3-70b-instruct   ${DIM}Llama · open${RESET}`)
    console.log(`  ${ACCENT}5${RESET}  Custom                              ${DIM}Enter model ID manually${RESET}`)
    console.log('')
    const orModelMap = {
      '1': 'deepseek/deepseek-chat-v3-0324',
      '2': 'anthropic/claude-sonnet-4-5',
      '3': 'google/gemini-2.0-flash-001',
      '4': 'meta-llama/llama-3.3-70b-instruct',
    }
    while (!model) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select model [1-5]: `)
      const key = (await readLine(false)).trim()
      if (orModelMap[key]) model = orModelMap[key]
      else if (key === '5') {
        process.stdout.write(`  ${ACCENT}›${RESET} Model ID (e.g. mistralai/mistral-7b-instruct): `)
        model = (await readLine(false)).trim()
        if (!model) { model = ''; console.log(`  ${RED}Model ID required${RESET}`) }
      } else console.log(`  ${RED}Pick 1–5${RESET}`)
    }
    providerEnv = { OPENAI_BASE_URL: 'https://openrouter.ai/api/v1', OPENAI_API_KEY: apiKey, OPENAI_MODEL: model }
  } else if (provider === 'evolink') {
    console.log(`  ${YELLOW}Step 2a/3${RESET} ${BOLD}Evolink API Key${RESET}`)
    console.log(`  ${GRAY}Get yours at: evolink.ai/dashboard/keys${RESET}`)
    console.log('')
    while (!apiKey) {
      process.stdout.write(`  ${ACCENT}›${RESET} Paste your API key: `)
      apiKey = (await readLine(true)).trim()
      if (!apiKey) console.log(`  ${RED}API key required${RESET}`)
    }
    console.log(`  ${GREEN}✔ Key saved${RESET}`)
    console.log('')

    console.log(`  ${YELLOW}Step 2b/3${RESET} ${BOLD}Choose your model${RESET}`)
    console.log('')
    console.log(`  ${ACCENT}1${RESET}  claude-sonnet-4-6          ${DIM}Latest Sonnet · smart${RESET}  ${GREEN}[recommended]${RESET}`)
    console.log(`  ${ACCENT}2${RESET}  claude-opus-4-6            ${DIM}Latest Opus · most capable${RESET}`)
    console.log(`  ${ACCENT}3${RESET}  claude-sonnet-4-5-20250929 ${DIM}Sonnet 4.5${RESET}`)
    console.log(`  ${ACCENT}4${RESET}  claude-haiku-4-5-20251001  ${DIM}Fast · cheap${RESET}`)
    console.log('')
    const evolinkModelMap = {
      '1': 'claude-sonnet-4-6',
      '2': 'claude-opus-4-6',
      '3': 'claude-sonnet-4-5-20250929',
      '4': 'claude-haiku-4-5-20251001',
    }
    while (!model) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select model [1-4]: `)
      const key = (await readLine(false)).trim()
      if (evolinkModelMap[key]) model = evolinkModelMap[key]
      else console.log(`  ${RED}Pick 1, 2, 3 or 4${RESET}`)
    }
    providerEnv = { ANTHROPIC_BASE_URL: 'https://direct.evolink.ai', ANTHROPIC_API_KEY: apiKey, ANTHROPIC_MODEL: model }
  } else if (provider === 'stepfun') {
    console.log(`  ${YELLOW}Step 2a/3${RESET} ${BOLD}StepFun API Key${RESET}`)
    console.log(`  ${GRAY}Get yours at: platform.stepfun.ai${RESET}`)
    console.log('')
    while (!apiKey) {
      process.stdout.write(`  ${ACCENT}›${RESET} Paste your API key: `)
      apiKey = (await readLine(true)).trim()
      if (!apiKey) console.log(`  ${RED}API key required${RESET}`)
    }
    console.log(`  ${GREEN}✔ Key saved${RESET}`)
    console.log('')

    // StepFun has two endpoints: /step_plan/v1 for monthly subscriptions,
    // /v1 for pay-as-you-go API credits — the wrong one 402s with quota_exceeded
    console.log(`  ${YELLOW}Step 2b/3${RESET} ${BOLD}How do you pay for StepFun?${RESET}`)
    console.log('')
    console.log(`  ${ACCENT}1${RESET}  Monthly coding plan   ${DIM}subscription${RESET}         ${GREEN}[most common]${RESET}`)
    console.log(`  ${ACCENT}2${RESET}  API credits           ${DIM}pay-as-you-go${RESET}`)
    console.log('')
    let stepfunBaseUrl = ''
    while (!stepfunBaseUrl) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select billing [1-2]: `)
      const key = (await readLine(false)).trim()
      if (key === '1') stepfunBaseUrl = 'https://api.stepfun.ai/step_plan/v1'
      else if (key === '2') stepfunBaseUrl = 'https://api.stepfun.ai/v1'
      else console.log(`  ${RED}Pick 1 or 2${RESET}`)
    }
    console.log('')

    console.log(`  ${YELLOW}Step 2c/3${RESET} ${BOLD}Choose your model${RESET}`)
    console.log('')
    // only tool-calling models — twin's agent loop needs tools
    console.log(`  ${ACCENT}1${RESET}  step-3.7-flash        ${DIM}Latest · fast${RESET}        ${GREEN}[recommended]${RESET}`)
    console.log(`  ${ACCENT}2${RESET}  step-3.5-flash        ${DIM}Fast · multimodal${RESET}`)
    console.log(`  ${ACCENT}3${RESET}  step-3.5-flash-2603   ${DIM}Pinned snapshot${RESET}`)
    console.log('')
    const stepfunModelMap = {
      '1': 'step-3.7-flash',
      '2': 'step-3.5-flash',
      '3': 'step-3.5-flash-2603',
    }
    while (!model) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select model [1-3]: `)
      const key = (await readLine(false)).trim()
      if (stepfunModelMap[key]) model = stepfunModelMap[key]
      else console.log(`  ${RED}Pick 1, 2 or 3${RESET}`)
    }
    providerEnv = { OPENAI_BASE_URL: stepfunBaseUrl, OPENAI_API_KEY: apiKey, OPENAI_MODEL: model }
  } else {
    // Custom OpenAI-compatible provider
    console.log(`  ${YELLOW}Step 2a/3${RESET} ${BOLD}Base URL${RESET}`)
    console.log(`  ${GRAY}e.g. https://openrouter.ai/api/v1 · https://api.together.xyz/v1 · http://localhost:11434/v1${RESET}`)
    console.log('')
    let baseUrl = ''
    while (!baseUrl) {
      process.stdout.write(`  ${ACCENT}›${RESET} Base URL: `)
      baseUrl = (await readLine(false)).trim()
      if (!baseUrl) console.log(`  ${RED}Base URL required${RESET}`)
    }
    console.log('')

    console.log(`  ${YELLOW}Step 2b/3${RESET} ${BOLD}Model name${RESET}`)
    console.log(`  ${GRAY}e.g. meta-llama/Llama-3.3-70B-Instruct · mistralai/Mixtral-8x7B${RESET}`)
    console.log('')
    while (!model) {
      process.stdout.write(`  ${ACCENT}›${RESET} Model: `)
      model = (await readLine(false)).trim()
      if (!model) console.log(`  ${RED}Model name required${RESET}`)
    }
    console.log('')

    console.log(`  ${YELLOW}Step 2c/3${RESET} ${BOLD}API Key${RESET} ${DIM}(press Enter to skip for local models)${RESET}`)
    console.log('')
    process.stdout.write(`  ${ACCENT}›${RESET} API key: `)
    apiKey = (await readLine(true)).trim()
    console.log(`  ${GREEN}✔ Saved${RESET}`)
    console.log('')

    providerEnv = { OPENAI_BASE_URL: baseUrl, OPENAI_API_KEY: apiKey || 'none', OPENAI_MODEL: model }
  }

  console.log(`  ${GREEN}✔ Provider set${RESET}`)
  console.log('')

  // Step 3: Obsidian vault
  console.log(`  ${YELLOW}Step 3/3${RESET} ${BOLD}Obsidian vault${RESET} ${DIM}(project memory)${RESET}`)
  console.log('')

  const vaults = detectObsidianVaults()
  let vaultPath = null

  if (vaults.length === 1) {
    // Single vault — just confirm
    const short = vaults[0].replace(homedir(), '~')
    process.stdout.write(`  ${ACCENT}›${RESET} Found vault: ${BOLD}${short}${RESET} — use it? [Y/n]: `)
    const answer = (await readLine(false)).trim().toLowerCase()
    if (answer === '' || answer === 'y' || answer === 'yes') {
      vaultPath = vaults[0]
    }
  } else if (vaults.length > 1) {
    // Multiple vaults — pick one
    console.log(`  Found ${vaults.length} vaults:`)
    console.log('')
    vaults.forEach((v, i) => {
      const short = v.replace(homedir(), '~')
      console.log(`  ${ACCENT}${i + 1}${RESET}  ${short}`)
    })
    console.log(`  ${ACCENT}s${RESET}  Skip`)
    console.log('')
    let picked = null
    while (picked === null) {
      process.stdout.write(`  ${ACCENT}›${RESET} Select vault [1-${vaults.length}/s]: `)
      const key = (await readLine(false)).trim().toLowerCase()
      if (key === 's' || key === 'skip') {
        picked = false
      } else {
        const idx = parseInt(key) - 1
        if (idx >= 0 && idx < vaults.length) {
          vaultPath = vaults[idx]
          picked = true
        } else {
          console.log(`  ${RED}Pick a number or s to skip${RESET}`)
        }
      }
    }
  } else {
    // Obsidian not found — ask manually
    console.log(`  ${DIM_GRAY}Obsidian not found. Enter your vault path or press Enter to skip.${RESET}`)
    console.log('')
    process.stdout.write(`  ${ACCENT}›${RESET} Vault path: `)
    const input = (await readLine(false)).trim()
    if (input && existsSync(input)) {
      vaultPath = input
    } else if (input) {
      console.log(`  ${RED}Path not found — skipping${RESET}`)
    }
  }

  if (vaultPath) {
    process.stdout.write(`  Setting up memory... `)
    const ok = setupMcpVenv()
    if (ok) {
      registerMcpServer(vaultPath)
      console.log(`${GREEN}✔${RESET}`)
      const short = vaultPath.replace(homedir(), '~')
      console.log(`  ${GREEN}✔ Vault connected: ${short}${RESET}`)
    } else {
      console.log(`${RED}✘${RESET}`)
      console.log(`  ${RED}python3 not found — skipping vault setup${RESET}`)
      console.log(`  ${DIM}Run: twin mcp add ... manually later${RESET}`)
    }
  } else {
    console.log(`  ${DIM_GRAY}Skipped — you can add a vault later with: twin mcp add${RESET}`)
  }

  console.log('')

  // Save settings
  mkdirSync(TWIN_DIR, { recursive: true })
  writeFileSync(SETTINGS_PATH, JSON.stringify({
    model,
    enableAllProjectMcpServers: false,
    enabledMcpjsonServers: [],
    enabledPlugins: {},
    ...(vaultPath ? { obsidianVault: vaultPath } : {}),
    env: providerEnv,
    permissions: {
      allow: [
        'Read(**)',
        'mcp__twin__get_project_context',
        'mcp__twin__log_session',
        'mcp__twin__update_progress',
        'mcp__twin__session_start',
        'mcp__twin__session_end',
        'mcp__twin__set_next_steps',
        'mcp__twin__set_project_context',
        'mcp__twin__save_knowledge',
        'mcp__twin__get_knowledge',
        'mcp__twin__list_knowledge',
        'mcp__twin__search_knowledge',
        'mcp__twin__delete_knowledge',
      ],
    },
  }, null, 2))

  // Clear screen before handing off
  process.stdout.write('\x1b[2J\x1b[H')
}

// Check if onboarding is needed
let needsOnboarding = true
if (existsSync(SETTINGS_PATH)) {
  try {
    const s = JSON.parse(readFileSync(SETTINGS_PATH, 'utf8'))
    if (s?.env?.OPENAI_BASE_URL && s?.env?.OPENAI_MODEL) needsOnboarding = false
    if (s?.env?.ANTHROPIC_BASE_URL && s?.env?.ANTHROPIC_MODEL) needsOnboarding = false
  } catch {}
}

// --version/--help must work without provider config, and onboarding can only
// run where raw-mode input exists (not in pipes, ssh exec, CI)
const argvFlags = process.argv.slice(2)
const skipOnboarding = ['--version', '-v', '--help', '-h'].some(f => argvFlags.includes(f))

if (needsOnboarding && !skipOnboarding) {
  if (!process.stdin.isTTY || typeof process.stdin.setRawMode !== 'function') {
    console.error('twin: no provider configured yet, and first-time setup needs an interactive terminal.')
    console.error('twin: run `twin` directly in a terminal to choose a provider.')
    process.exit(1)
  }
  await runOnboarding()
}

// Apply provider env from settings before the app starts
if (existsSync(SETTINGS_PATH)) {
  try {
    const s = JSON.parse(readFileSync(SETTINGS_PATH, 'utf8'))
    if (s?.env) {
      for (const [k, v] of Object.entries(s.env)) {
        if (typeof v === 'string') process.env[k] = v
      }
    }
  } catch {}
}

// Only use OpenAI-compatible shim for non-Anthropic-native providers
if (!process.env.ANTHROPIC_BASE_URL) {
  process.env.CLAUDE_CODE_USE_OPENAI = '1'
}
process.env.LOCALCODE_ROOT = join(__dirname, '..')

// Migrate: ensure settings.json has twin-memory permissions for all users
if (existsSync(SETTINGS_PATH)) {
  try {
    const s = JSON.parse(readFileSync(SETTINGS_PATH, 'utf8'))
    const required = [
      'Read(**)',
      'mcp__twin__get_project_context', 'mcp__twin__log_session',
      'mcp__twin__update_progress', 'mcp__twin__session_start', 'mcp__twin__session_end',
      'mcp__twin__set_next_steps', 'mcp__twin__set_project_context',
      'mcp__twin__save_knowledge', 'mcp__twin__get_knowledge',
      'mcp__twin__list_knowledge', 'mcp__twin__search_knowledge', 'mcp__twin__delete_knowledge',
    ]
    const existing = s?.permissions?.allow ?? []
    const missing = required.filter(r => !existing.includes(r))
    if (missing.length > 0) {
      if (!s.permissions) s.permissions = {}
      s.permissions.allow = [...existing, ...missing]
      writeFileSync(SETTINGS_PATH, JSON.stringify(s, null, 2))
    }
  } catch {}
}

// Migrate: ensure twin MCP alwaysAllow has all required tools (merge-missing)
if (existsSync(CLAUDE_JSON_PATH)) {
  try {
    const config = JSON.parse(readFileSync(CLAUDE_JSON_PATH, 'utf8'))
    const server = config?.mcpServers?.['twin']
    if (server) {
      const alwaysRequired = [
        'get_project_context', 'log_session', 'update_progress', 'session_start', 'session_end',
        'save_knowledge', 'get_knowledge', 'list_knowledge', 'search_knowledge', 'delete_knowledge',
        'set_next_steps', 'set_project_context',
      ]
      const existingAllow = server.alwaysAllow ?? []
      const missingAllow = alwaysRequired.filter(t => !existingAllow.includes(t))
      if (missingAllow.length > 0) {
        server.alwaysAllow = [...existingAllow, ...missingAllow]
        writeFileSync(CLAUDE_JSON_PATH, JSON.stringify(config, null, 2))
      }
    }
  } catch {}
}

if (!existsSync(distPath)) {
  console.error('twin: run "npm run build" first')
  process.exit(1)
}

if (process.stdout.isTTY) process.stdout.write('\x1b[2J\x1b[H')

await import(pathToFileURL(distPath).href)
